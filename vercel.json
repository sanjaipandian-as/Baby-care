{
  "rewrites": [
    {
      "source": "/",
      "destination": "/baby-workshop-clone.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/image/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
